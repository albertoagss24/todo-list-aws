pipeline {
    agent any
    options { skipDefaultCheckout(true) } // Se salta el checkout implícito del repositorio que realiza Jenkins por defecto
    environment {
        STACK  = 'todo-list-aws-staging'
        REGION = 'us-east-1'
        REPO   = 'https://github.com/albertoagss24/todo-list-aws.git'
    }
    
    stages {

        stage('Get Code') {
            steps {
                git branch: 'develop', url: "${REPO}"
            }
        }
    }
}