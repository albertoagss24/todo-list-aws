pipeline {
    agent any
    options { skipDefaultCheckout(true) } // Se salta el checkout implícito del repositorio que realiza Jenkins por defecto
    environment {
        STACK  = 'todo-list-aws-production'
        REGION = 'us-east-1'
        REPO   = 'https://github.com/albertoagss24/todo-list-aws.git'
    }
    
    stages {

        stage('Get Code') {
            steps {
                git branch: 'master', url: "${REPO}"
            }
        }
        
        stage ('Deploy') {
            steps {
                sh 'sam build'
                sh 'sam deploy --config-env production --no-confirm-changeset --no-fail-on-empty-changeset'
                script {
                    env.BASE_URL = sh(
                        returnStdout: true,
                        script: "aws cloudformation describe-stacks --stack-name ${STACK} --region ${REGION} --query \"Stacks[0].Outputs[?OutputKey=='BaseUrlApi'].OutputValue\" --output text"
                    ).trim()
                }
                echo "BASE_URL = ${env.BASE_URL}"
            }
        }
        
        stage ('Rest Test') {
            steps {
                sh "BASE_URL=${env.BASE_URL} python3 -m pytest -k 'test_api_listtodos or test_api_gettodo' --junitxml=result-rest.xml test/integration/todoApiTest.py"
            }
            post {
                always { junit 'result-rest.xml' }
            }
        }
    }
}